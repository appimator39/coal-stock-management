# Turso database (required)
# Sign up at https://turso.tech and create a database, then:
#   turso db create coal-tracker
#   turso db show coal-tracker --url
#   turso db tokens create coal-tracker
TURSO_DATABASE_URL=libsql://your-db-name-your-username.turso.io
TURSO_AUTH_TOKEN=

# JWT signing secret (required — min 32 chars)
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Optional: Vite dev server API proxy target.
# If not set, defaults to http://localhost:3000 (run `vercel dev`).
VITE_API_PROXY=
